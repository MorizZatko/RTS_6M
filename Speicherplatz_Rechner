"""
Module: Storage Calculator
Description: This tool calculates the needed storage space through user input by frames and megabyte size per frame.
Function:
    1. Asks user for total number of frames (int).
    2. Aks user for megabyte size per frame and format commas to dots (float).
    3. Calculates the needed size and outputs it as a string in gigabyte.
Args:
    None: Source frame count and size per frame is provided via standard input.
Returns:
    None: Tool outputs the needed storage space as a string with two decimal places.
"""


Number = int(input("Frames:"))
Size = float(input("Dateigröße in MB per Frame:").replace(",", "."))

MB_Size = Number * Size
GB_Size = MB_Size / 1024    # transfer megabyte to gigabyte

print(f"Die Datei benötigt {GB_Size:.2f} GB.")