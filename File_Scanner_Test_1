import os
import shutil

""""
Modulzweck: Versions-Nummer in Dateinamen um 1 erhöhen.

Der Code scannt den vomm Benutzer gegebenen Quellordner nach Dateien,
die eine Versions-Nummer im Dateinamen haben (z.B. vXxxx.ext).
Die Datei mit der höchsten Versions-Nummer wird um 1 erhöht und als Kopie mit neuer Versions-Nummer auf dem gleichen Pfad gespeichert.
Über die Standard-Ausgabe wird die Datei mit der neuen Versions-Nummer ausgegeben sowie ein vergleich zwischen dem original und dem neuen Namen,
bei erfolgreichen kopier vorgang wird dies auch über die Standard-Ausgabe ausgegeben.

Args:
    None. Der Notwendige String (Quellortdner Pfad) wird über die Standard-Input Eingabe bereitgestellt.

Returns:
    None. Die finalen Strings werden über die Standart-Ausgabe print() ausgegeben.
"""

user_input = input("Bitte den Pfad zum Ordner eingeben: ") # C:\Users\moriz\Desktop\python_test
real_path = user_input.replace('"', '').strip()     # alle "" werden gelöscht die durchs Windows kopieren entstehen, durch .strip() werden alle leerzeichen am Anfang und am Ende gelöscht

if not os.path.exists(real_path):   # Wenn der angegebene Pfad nicht existiert wird folgender Code ausgeführt
    print(f"FEHLER: Der Pfad '{real_path}' existiert nicht!")   # Fehlermeldung wird ausgegeben.
    exit()  # Nach einem durchlauf wird das Programm beendet

files = os.listdir(real_path)   # In der neuen Varibale files werden alle Pfade der Dateien die sich im angebenen Pfad befinden, als Liste gespeichert
all_versions = []   # Neue Variable all_versions wird als leere Liste definiert
extension = ""      # Neue Variable extensions wird als leerer String definiert

for file_name in files:     # Für jedes Element, hier als file_name definiert, wird in der Liste files folgender Code ausgeführt
    name = file_name[0:-4]      # Aus dem Element file_name werden alle Zeichen bis auf die letzten 4 extrahiert und als Variable name definiert
    path = os.path.join(real_path, file_name)   # die Variable path wird als f-string definiert aus den Variablen real_path und file_name, durch .replace() werden alle \ durch / ersetzt
    if name.startswith("v") and name[1:].isdigit():     # Wenn die Variable name mit v beginnt und die Zeichen nach dem ersten Index der Variable Zahlen sind, wird folgender Code ausgeführt
        version_num = int(name[1:])     # Die Variable name ab dem zweiten Zeichen wird zum Integer und als Variable version_num definiert
        all_versions.append(version_num)        # Die Variable version_num wird zur Liste all_versions hinzugefügt

        if version_num == max(all_versions, default=0):     # Wenn die Variable version_num der höchsten Variable in der Liste all_versions gleicht, wobei der start Wert 0 ist, soll folgender Code ausgeführt werden
             extension = file_name[-4:]     # Die variable extensions wird neu definiert mit den letzten 4 Zeichen des letzten Wertes der Variable file_name

if not all_versions:    # Wenn die all_versions Liste leer bleibt bzw False ausgibt wird folgender Code ausgeführt
    print("Keine Datei mit Versions-Nummer gefunden!")  # Fehlermeldung wird ausgegeben
    exit()      # Nach einem durchlauf wird die Schleife beendet

if all_versions: # Wenn die all_versions Liste Daten gespeichert hat bzw True ausgibt wird folgender Code ausgeführt
    highest_v = max(all_versions)   # definiert die Variable highest_v mit dem höchsten Wert der Liste all_versions
    new_v = highest_v + 1       # addiert die Variable highest_v mit 1 und definiert sie als new_v
    print(f"Die Datei mit der Höchsten Versions-Nummer ist: v{new_v:03d}{extension}")   # gibt aus welche Datei dn höchsten Wert (v-nummer) hat

    old_file = f"v{highest_v:03d}{extension}"   # Variable old_file wird als f-string definiert der sich aus den Variablen highest_v und extensions zusammensetzt
    new_file = f"v{new_v:03d}{extension}"       # Vairable new_file wird als f-string definiert der sich aus den Variablen new_v und extensions zusammensetzt
    print(f"Old file: {old_file}\nNew file: {new_file}")    # gibt den alten und neuen Dateinamen aus

    old_path = os.path.join(real_path, old_file).replace("\\", "/")     # Vairable old_path definiert sich aus dem zusammenfügen der Variablen real_path und old_file, alle \ werden durch / erstezt
    new_path = os.path.join(real_path, new_file).replace("\\", "/")     # Vairable new_path definiert sich aus dem zusammenfügen der Variablen real_path und new_file, alle \ werden durch / erstezt
    print(f"Old Path: {old_path}\nNew Path: {new_path}")        # gibt alten und neuen Pfad aus

    if not os.path.exists(new_path):        # Wenn der neue Pfad new_path nicht im angegebenen Pfad existiert soll folgender Code ausgeführt werden
        shutil.copy(old_path, new_path)     # alter Pfad old_path wird zu neuem Pfad new_path kopiert
        print(f"Update: {old_file} wurde zu {new_file} kopiert!")    # gibt aus wenn die Datei erfolgreich kopiert wurde
    
else:   # Wenn die all_versions Liste leer bleibt bzw False ausgibt wird folgender Code ausgeführt
    print("Keine Version zum erhöhen gefunden...")

