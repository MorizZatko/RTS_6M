path = [
    "/mnt/server/Projekte/Shot01/Render/Unterordner/v001/image.0001.exr",
    "/mnt/server/Projekte/Shot02/Render/Unterordner/Versions/v008/image.0001.exr",
    "/mnt/server/Projekte/Shot03/Render/v012/image.0001.exr"
]       # Nested List mit 3 verschieden langen Pfaden

for single_path in path:    # Loop (Iterationsvariable) der der Variable Single_path definiert und sagt was sie mit der Variable path machen soll
    split = single_path.strip("/").split("/")   # teilt die Variable bei allen / die .strip Methode löscht alle / des Linux Pfades

    path_start = "/".join(split[:-2])   # extrahiert alle Strings bis zum 2. letzten Element und klebt zwischen jedes Element ein /

    path_version = split[-2]    # extrahiert das 2. letzte Element der Liste
    path_version_number = int(path_version[1:]) + 1     # ändert den Inhalt der path_version variable von String zu Integer und addiert 1 (Die Variable selbst bleibt ein String)
    path_new_number = f"v{path_version_number:03d}"     # definiert die Variable path_new_number als String mit einer Variable die, v am Anfang für die v der Versions-Nummer, das :03d füllt alle leeren stell mit 0 auf, sagt das es min 3 stellen gibt und das d steht für digit (ganze Zahlen) 

    path_end = split[-1]       # extrahiert das letzte Element

    print(f"/{path_start}/{path_new_number}/{path_end}")    # fügt alle Elemente zusammen mit / zwischen jedem Element
