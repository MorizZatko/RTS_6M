"""
Code dient zur kurzen übung veranschaulichung der String-Methode '.strip()'.
Benutzer abfrage nach Vor- und Nach-Name und zeigt 3 verschiedene Formatierungen der Eingabe.

Args:
    None. Die Strings Vor- und Nach-Name werden über den Standard Input gegeben.

Returns:
    None. Die 3 finalen formatierten Strings werden über den Standard-Ausgabe print() ausgegeben,
"""
Vorname = input("Wie lautet dein Vorname?")
Nachname = input("Wie lautet dein Nachname?")

print(f"{Vorname.strip()} {Nachname.strip()}")
print(f"{Nachname.strip()}, {Vorname.strip()}")
print(f"{Vorname.strip()[0]}.{Nachname.strip()[0]}.")