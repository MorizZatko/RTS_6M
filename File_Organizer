import os
import shutil
import datetime

"""
Module: File Organizer (file types)
Description: This module sorts all files in a selected directory.
             Every file gets moved into a subfolder in the source directory, the subfolder is named after the file type.
Function:
    1. Asks user for the source directory via standard input.
    2. Ignores all files in 'blacklist'.
    3. Moves every file into a subfolder named after the filetype (z.B. '.jpg' oder '.pdf')
    4. Provides a final statistic of the results. 
    Statistic shows:
        - Timestamp and Date (datetime)
        - Total file count (int)
        - Successfully sorted files (int)
        - Failed files (int)
Args:
    None: Source directory is provided via standard input.
Returns:
    None: Module outputs a statistic of the process via standard output.
"""

def show_stats(alle, erfolg, fehler, zeit):
    """Displays the final statistic of the sorting process.

    Args:
        alle (int): total count of all scanned files.
        erfolg (int): number of all successfully moved files.
        fehler (int): number of all failed files.
        zeit (str): Timestamp as a string.

    Returns:
        None: Outputs via print().
    
    """
    print(f"\n==========================")
    print(f"Zusammenfassung vom {zeit}")
    print(f"Alle Dateien: {alle}")
    print(f"Erfolgreich: {erfolg}")
    print(f"Fehlgeschlagen: {fehler}")
    print(f"==========================\n")

def take_ext(file_name):
    """Extracts the filetype from the filename.

    Args:
        file_name (str): Complete filename. 
    
    Returns:
        str: Filetype without dots and lowercased, fallback: 'Ohne Endung'.
    """
    if "." in file_name:
        return file_name.split(".")[-1].lower()
    else:
        return "Ohne Endung"
    
# --- Main Logic ---

path_input = input("Zu sortierenden Pfad eingeben: ")   # Asks user to select the source directory
target_dir = path_input.replace('"', '')    # Removes quotes from windows copy process
file_list = os.listdir(target_dir)  # all files get stored in 'file_list' as a list
blacklist = ["File_organizer.py", "Desktop.ini", ".DS_Store"]  # 'blacklist' stores every file that should not be moved
file_count = 0  # Initialize file counter with int 0
file_count_true = 0 # Initialize successfully moved counter with int 0
file_count_false = 0   # Initialize failed files counter with int 0
start_time = datetime.datetime.now()    # starts timer for the sorting process

for file in file_list:  # Iterate through every filename in the list
    full_path = os.path.join(target_dir, file)  # Combines the source path with the filename into a full path string
    
    if os.path.isfile(full_path):   # Checks if 'full_path' matches a file in the directory
        file_count += 1
        if file in blacklist or file.endswith(".exe"):  # Skips all files listed in 'blacklist' or files that end with .exe
            continue    # Continue to next file

        try:  
            ext = take_ext(file)    
            subfolder = os.path.join(target_dir, ext)   # Combines modified source path with the file type
            os.makedirs(subfolder, exist_ok=True)   # Generates the new subfolder (only if it doesnt already exists)
            new_filepath = os.path.join(subfolder, file)   # Combines subfolder path and filename to the new file path
            shutil.move(full_path, new_filepath)    # Moves file from source directory to the new subfolder
            file_count_true += 1     # Counts every successfully moved file

        except Exception as e: 
            print(f"\033[31m FEHLER! Die Datei {file}: {e} konnte nicht verschoben werden...\033[0m")   # Fallback with error message
            file_count_false += 1   # Counts every failed file

end_time = datetime.datetime.now()      # Stops timer and save it to 'end_time' variable
time_string = end_time.strftime("%d.%m.%Y um %H:%M:%S Uhr")     # Formating the time string
show_stats(file_count, file_count_true, file_count_false, time_string)  # Displays the final statistic

with open("File_Organizer.txt", "a", encoding="utf-8") as log:  # Creates a log file as 'File_Organizer.txt'
    log.write(f"\n---Sortierung am {time_string}---\n")
    log.write(f"Erfolgreich: {file_count_true} | Fehlgeschlagen: {file_count_false}\n")
    log.write("----------------------------------------------\n")

input("\nDrücke Enter um das Programm zu beenden...")   # User info to close this module
