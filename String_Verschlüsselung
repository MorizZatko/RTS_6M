word = input("Zu verschlüsselndes Wort:") 

start = word[0]     # Extrahiert dem ersten Index
last = word[-1]     # Extrahiert dem letzten Index
mid = word[1:-1]    # Extrahiert alle Indexs zwischen dem ersten un dem letzten
length = len(word)  # Extrahiert die Anzahl der Indexs als Zahl

new_word = last + mid + start + str(length) # fügt alle Indexe in einer neuen Reihenfolge zusammen

print(f"{new_word}")